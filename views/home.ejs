<!doctype html>
<html>
<head>
<title>Hidden chat</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Ubuntu:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap"
            rel="stylesheet"
        />
  <link href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css" rel="stylesheet">

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&icon_names=send" />
</style>
</head>
<body>
<div class="glass-container">
<h1>Hidden Chat</h1>
<p class="glass-container" id="p">
Type your message and i deliver it to Airp anonymously.
</p>
<div id="screen">
<input type="text" id="input" placeholder="Type your message here..." class="glass-container" maxlength="1000">
<button id="btn"><span class="material-symbols-outlined">
send
</span></button>
</div>
<p id="note" class="glass-container">Note: i have your ip address little nigga</p>
</div>
<style>
body{
background: #300000;
background: linear-gradient(311deg, rgba(30, 0, 0, 1) 0%, rgba(115, 0, 0, 1) 50%, rgba(184, 0, 0, 1) 100%);
width: 400px;
margin-left: auto;
margin-right: auto;
text-align: center;
font-family: "Ubuntu", sans-serif;
margin-top: 90px;
}
            .glass-container {
                background: rgba(0, 0, 0, 0.05);
                text-align: center;
                color: white;
                backdrop-filter: blur(10px);
                padding: 25px;
                border-radius: 20px;
                border: solid 1px rgba(0, 0, 0, 0.2);
                box-shadow: 3px 3px 3px rgba(0, 0, 0, 0.1);
            }

html{
height: 100%;
}

#input{
width: 290px;
height: 0.5px;
border-radius: 20px;
font-family: 'Vazirmatn', sans-serif;
}
#note{
font-size: 15px;
}

#screen{
    display: flex;
}

button{
    background: rgba(0, 0, 0, 0.05);
    text-align: center;
    color: white;
    backdrop-filter: blur(10px);
    padding: 11px;
border-radius: 20px;
    border: solid 1px rgba(0, 0, 0, 0.2);
    box-shadow: 3px 3px 3px rgba(0, 0, 0, 0.1);
    margin-left: 5px;
    cursor: pointer;
}
</style>
<script>
const textArea = document.getElementById("input");
const status = document.getElementById("note");
const btn = document.getElementById("btn");

btn.addEventListener("click", (e) => {
  const text = textArea.value;

  fetch("/messages", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({ text: text })
  })
    .then((res) => res.json())
    .then((data) => {
      if (data.success) {
        textArea.value = "";
        status.textContent = "Message sent!";
      } else {
        status.textContent = "Error: " + data.error;
      }
    })
    .catch((err) => {
      status.textContent = "Something went wrong. Try again.";
    });
});
</script>
</body>
</html>
